{
	"name": "multiplewordshighlighter-vscode",
	"displayName": "MultipleWordsHighlighter_vscode",
	"description": "",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.90.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCommand:multiplewordshighlighter-vscode.helloWorld"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "multiplewordshighlighter-vscode.helloWorld",
				"title": "Hello World"
			}
		],
		"configuration": {
			"properties": {
				"conf.resource.01.backgroundColor": {
				  "type": "string",
				  "default": "#FF000055",
				  "description": "背景色",
				  "pattern": "#[0-9a-fA-F]{8}",
				  "maxLength": 9
				},
				"conf.resource.01.borderStyleSolid": {
					"type": "boolean",
					"default": true,
					"description": "枠色の有無"
				},
				"conf.resource.01.borderStyleColor": {
					"type": "string",
					"default": "#FF0000FF",
					"description": "枠色",
					"pattern": "#[0-9a-fA-F]{8}",
					"maxLength": 9
				},
				"conf.resource.02.backgroundColor": {
					"type": "string",
					"default": "#FFC7CEFF",
					"description": "背景色",
					"pattern": "#[0-9a-fA-F]{8}",
					"maxLength": 9
				},
				"conf.resource.02.borderStyleSolid": {
					"type": "boolean",
					"default": true,
					"description": "枠色の有無"
				},
				"conf.resource.02.borderStyleColor": {
					"type": "string",
					"default": "#FF0000FF",
					"description": "枠色",
					"pattern": "#[0-9a-fA-F]{8}",
					"maxLength": 9
				}
			}
		},
		"views": {
			"multiplewordshighlighter-explorer": [
				{
					"type": "webview",
					"id": "example.webview",
					"name": ""
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "multiplewordshighlighter-explorer",
					"title": "multiplewordshighlighter Explorer",
					"icon": "media/dep.svg"
				}
			]
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/vscode": "^1.90.0",
		"@types/glob": "^7.1.4",
		"@types/mocha": "^9.0.0",
		"@types/node": "14.x",
		"@typescript-eslint/eslint-plugin": "^4.31.1",
		"@typescript-eslint/parser": "^4.31.1",
		"eslint": "^7.32.0",
		"glob": "^7.1.7",
		"mocha": "^9.1.1",
		"typescript": "^4.4.3",
		"@vscode/test-electron": "^1.6.2"
	}
}
